# Vercel → Project → Settings → Environment Variables (Production + Preview)
#
# You need at least one of: Resend (email) OR Google Sheet below.

RESEND_API_KEY=re_xxxxxxxx
LEAD_NOTIFICATION_EMAIL=you@yourdomain.com

# Optional — must verify domain in Resend first
# RESEND_FROM_EMAIL=Orca <leads@yourdomain.com>

# Google Sheet: create a project in Google Cloud Console → APIs → enable "Google Sheets API"
# → IAM → Service Accounts → create key (JSON). Copy the whole JSON into Vercel as one var.
# Open your sheet → Share → add the service account email (from the JSON) as Editor.
# Sheet URL: https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional sheet tab / columns (default Sheet1 and A:H). Put this in row 1:
# Timestamp | Email | Phone | Postcode | Annual bill | Discount % | Est. Orca bill | Est. saving
# GOOGLE_SHEET_TAB=Sheet1
# GOOGLE_SHEET_RANGE=A:H

# Local Vite: set to "true" to POST leads while on localhost (needs `vercel dev`)
# VITE_SUBMIT_LEADS=true
